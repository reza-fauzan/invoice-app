# ==============================
# Laravel .gitignore
# ==============================

# === Environment Files ===
.env
.env.backup
.env.production
.env.staging
.env.local

# === Dependencies ===
/vendor
/node_modules

# === Build Output ===
/public/build
/public/hot
/public/storage
/public/fonts-manifest.dev.json

# === Storage ===
/storage/*.key
/storage/pail

# === Log Files ===
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# === Cache & Compiled ===
/.phpunit.cache
.phpunit.result.cache
bootstrap/cache/*.php

# === IDE & Editor Files ===
/.idea
/.vscode
/.cursor/
/.nova
/.zed
/.codex
.phpactor.json
_ide_helper.php
_ide_helper_models.php
.phpstorm.meta.php
*.swp
*.swo
*~

# === OS Generated Files ===
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# === Auth & Keys ===
/auth.json
Homestead.json
Homestead.yaml

# === Misc ===
.phpunit.result.cache
